// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Emulate relations in Prisma (no DB-level foreign keys). Chosen because the
  // order tables share legacy data that predates OrderSnapshot, so a hard FK
  // could reject existing orphan rows on deploy.
  relationMode = "prisma"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model AppSetting {
  id                         String   @id @default(cuid())
  shop                       String   @unique
  fuelSurchargePercent       Decimal  @default(0) @db.Decimal(10, 2)
  additionalCostType         CostType @default(FIXED)
  additionalCostValue        Decimal  @default(0) @db.Decimal(10, 2)
  defaultCurrency            String   @default("NZD")
  defaultServiceType         ServiceType @default(STANDARD_DELIVERY)
  fafFliway       Decimal  @default(30.5)
  fafFliwayMidsize Decimal  @default(30.5)
  fafMainfreight  Decimal  @default(36.35)
  fafTge          Decimal  @default(29.8)
  fafM2h          Decimal  @default(0)
  tgeAdminFee     Decimal  @default(12.69)
  homeDeliveryFeeFliway        Decimal  @default(45) @db.Decimal(10, 2)
  homeDeliveryFeeFliwayMidsize Decimal  @default(45) @db.Decimal(10, 2)
  homeDeliveryFeeTge           Decimal  @default(25) @db.Decimal(10, 2)
  mainfreightDepotFee          Decimal  @default(25) @db.Decimal(10, 2)
  marginRate      Decimal  @default(10) @db.Decimal(10, 2)
  gstRate         Decimal  @default(15) @db.Decimal(10, 2)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ShippingRate {
  id             String      @id @default(cuid())
  shop           String
  company        CarrierCompany
  serviceType    ServiceType
  city           String
  sector         String?     
  postalCode     String
  useWeightRange Boolean     @default(false)
  minWeightGrams Int?
  maxWeightGrams Int?
  useVolumeRange Boolean     @default(false)
  minVolumeCm3   Int?
  maxVolumeCm3   Int?
  rate           Decimal     @db.Decimal(10, 4)
  zoneSurcharge  Decimal     @default(0) @db.Decimal(10, 2)
  minimumCharge  Decimal     @default(0) @db.Decimal(10, 2)
  baseFee        Decimal     @default(0) @db.Decimal(10, 2)
  homeDeliveryFee Decimal?   @db.Decimal(10, 2)
  signatureSurcharge     Decimal @default(0) @db.Decimal(10, 4)
  ruralSurcharge         Decimal @default(0) @db.Decimal(10, 4)
  ageRestrictedSurcharge Decimal @default(0) @db.Decimal(10, 4)
  residentialFee Decimal @default(0) @db.Decimal(10, 2)
  mode           CarrierMode?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([shop, active, company, serviceType])
  @@index([shop, city, postalCode])
}

model OrderSnapshot {
  id              String   @id @default(cuid())
  shop            String
  orderId         String
  orderName       String   @default("")
  email           String   @default("")
  phone           String   @default("")
  currencyCode    String   @default("NZD")
  totalPrice      String   @default("0")
  financialStatus String   @default("")
  fulfillmentStatus String @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Shipping address
  shippingFirstName String @default("")
  shippingLastName  String @default("")
  shippingAddress1  String @default("")
  shippingCity      String @default("")
  shippingProvince  String @default("")
  shippingZip       String @default("")
  shippingCountry   String @default("")

  // Parsed freight info from shipping line code
  carriers       String   @default("")
  packageCount   String   @default("")
  shippingTitle  String   @default("")
  shippingCode   String   @default("")
  totalFreight   Decimal  @default(0) @db.Decimal(10, 2)

  // Raw line items JSON (for detail page)
  lineItemsJson  String   @default("[]")

  // Relations — one order (snapshot) owns its operational + index rows.
  operational  OrderOperationalData?
  lineItemOps  OrderLineItemOperationalData[]
  lineIndex    OrderLineItemIndex[]

  @@unique([shop, orderId])
  @@index([shop, createdAt])
}

model OrderOperationalData {
  id              String   @id @default(cuid())
  shop            String
  orderId         String
  customerStatus  String   @default("")
  warehouseStatus String   @default("")
  dispatchStatus  String   @default("")
  trackingNumber  String   @default("")
  deliveryStatus  String   @default("")
  poNumber        String   @default("")
  depositPaid     String   @default("")
  balanceDue      String   @default("")
  notes               String   @default("")
  eddDate             String   @default("")
  supplierContainer   String   @default("")
  portArrivalDate     String   @default("")
  inTransitDate       String   @default("")
  cin7SalesOrderId    String   @default("")
  cin7StatusCheckedAt DateTime?
  mondayStatusCheckedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order OrderSnapshot @relation(fields: [shop, orderId], references: [shop, orderId])

  @@unique([shop, orderId])
}

model OrderLineItemOperationalData {
  id                String   @id @default(cuid())
  shop              String
  orderId           String
  variantId         String
  productTitle      String   @default("")   
  carrier           String   @default("")
  customerStatus    String   @default("")
  customerStatusUpdatedAt DateTime?   // NEW
  paymentStatus     String   @default("")
  warehouseStatus   String   @default("")
  dispatchStatus    String   @default("")
  deliveryStatus    String   @default("")
  trackingNumber    String   @default("")
  trackingNumberUpdatedAt DateTime?   // NEW
  freightRef        String   @default("")  
  eddDate           String   @default("")
  eddDateUpdatedAt        DateTime?   // NEW
  originalEddDate   String   @default("")
  mondayItemId      String   @default("")
  depositPaid       String   @default("")
  balanceDue        String   @default("")
  notes             String   @default("")
  notesPushedCount  Int      @default(0)  
  notesPushedMondayItemId String? // NEW
  notesPulledUpdateIds    String   @default("")
  supplierContainer String   @default("")
  portArrivalDate   String   @default("")
  inTransitDate     String   @default("")
  cin7SalesOrderId  String   @default("")
  cin7CachedStatus  String   @default("")
  cin7CachedMismatches String @default("")
  mondayCachedStatus  String   @default("")
  mondayCachedMismatches String @default("")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order OrderSnapshot @relation(fields: [shop, orderId], references: [shop, orderId])

  @@unique([shop, orderId, variantId])
  // Speeds the list tab-filter + count FILTER on customer status.
  @@index([shop, customerStatus])
}

// Denormalized index: one row per FREIGHT line item. Immutable order/item
// snapshot data used to power the freight-orders LIST page with DB-side search,
// filter, sort and pagination (mutable status/tracking stays in
// OrderLineItemOperationalData and is joined live). Populated by the order
// webhooks (create/update) and the backfill route; keyed to match the ops table
// for the join.
model OrderLineItemIndex {
  id             String   @id @default(cuid())
  shop           String
  orderId        String
  variantId      String
  shopifyOrderId String   @default("")
  gid            String   @default("")
  orderName      String   @default("")
  letterSuffix   String   @default("")
  customerName   String   @default("")
  email          String   @default("")
  phone          String   @default("")
  city           String   @default("")
  zip            String   @default("")
  fullAddress    String   @default("")
  createdAt      DateTime @default(now())
  currency       String   @default("NZD")
  totalFreight   Decimal  @default(0) @db.Decimal(10, 2)
  carriers       String   @default("")
  shippingTitle  String   @default("")
  productTitle   String   @default("")
  productId      String   @default("")
  variantTitle   String   @default("")
  sku            String   @default("")
  vendor         String   @default("")
  company        String   @default("")
  boxes          Int      @default(0)
  amount         Decimal  @default(0) @db.Decimal(10, 2)
  financialStatus   String @default("")
  fulfillmentStatus String @default("")
  // Lowercased concatenation of the searchable fields (orderName, customerName,
  // email, carriers, productTitle, sku). A pg_trgm GIN index on this (added in
  // the migration SQL — Prisma can't express GIN) makes `ILIKE '%q%'` search
  // index-backed instead of a full scan at scale.
  searchText        String @default("")

  order OrderSnapshot @relation(fields: [shop, orderId], references: [shop, orderId])

  @@unique([shop, orderId, variantId])
  // Matches the list ORDER BY so paginated reads are an ordered index scan.
  @@index([shop, createdAt(sort: Desc), orderId(sort: Desc), letterSuffix])
  @@index([shop, createdAt])
}

model ExternalUser {
  id            String            @id @default(cuid())
  shop          String
  name          String
  email         String
  passwordHash  String            @default("")
  isActive      Boolean           @default(false)
  inviteToken   String?           @unique
  inviteExpires DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      ExternalSession[]

  @@unique([shop, email])
}

model ExternalSession {
  id        String       @id @default(cuid())
  userId    String
  token     String       @unique
  expiresAt DateTime
  createdAt DateTime     @default(now())

  user ExternalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CostType {
  FIXED
  PERCENTAGE
}

enum CarrierCompany {
  FLIWAY
  FLIWAYLINEHAUL
  FLIWAYMIDSIZE
  NZP
  NZP_AGE_RESTRICTED
  CASTLE
  TGE
  M2H
  MAINFREIGHT
}

enum ServiceType {
  STANDARD_DELIVERY
  DEPOT_DELIVERY
  CUSTOMER_PICKUP
}

enum CarrierMode {
  AIR
  ROAD
}
